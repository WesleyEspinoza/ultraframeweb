# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Product catalog (required in production — no local data/ folder on serverless)
STRIPE_PRODUCT_ID=prod_...
STRIPE_PRICE_ID=price_...

# Optional: fixed coupon when sale.json is enabled
# STRIPE_SALE_COUPON_ID=

# Webhooks — Dashboard endpoint or `stripe listen --forward-to <url>/api/stripe/webhooks`
STRIPE_WEBHOOK_SECRET=whsec_...

# Public site URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Microsoft Clarity — https://www.npmjs.com/package/@microsoft/clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=x03s4itvv3

# Installer file served after verified purchase (default shown below)
# INSTALLER_DOWNLOAD_URL=https://api.softwarerefresh.com/ultraframe/installer/download

# License API (defaults to Software Refresh production API)
# LICENSE_API_BASE_URL=https://api.softwarerefresh.com/ultraframe/api/license

# Help form (SMTP) — messages delivered to TO_EMAIL
# ALLOWED_ORIGIN=https://your-production-domain.com
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_USER=your-smtp-user@gmail.com
# EMAIL_PASS="your-gmail-app-password"
# TO_EMAIL=softwarerefreshquotes@gmail.com
